POSTGRES_DB=tender
POSTGRES_USER=tender
POSTGRES_PASSWORD=change-me

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_RAW=tender-raw
MINIO_BUCKET_EXPORT=tender-export

OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_TRANSPORT_PORT=9600
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMe_123!
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_VERSION=3.3.1

BACKEND_PORT=8000
AI_GATEWAY_PORT=8100
FRONTEND_PORT=3000

# Development convenience only. Production must use DB sessions or explicit
# AUTH_TOKENS and must not rely on the built-in dev-token fallback.
AUTH_TOKENS=
VITE_ENABLE_DEV_AUTH=false
VITE_DEV_AUTH_TOKEN=dev-token

# Shared bearer secret used by backend workers/services when calling AI Gateway.
# Set a strong random value in any shared or production-like environment.
AI_GATEWAY_SHARED_SECRET=change-me-local-only
CHART_AI_GATEWAY_TIMEOUT_SECONDS=8

# Backend template / evidence path controls.
# Use absolute container-visible paths in compose or deployment environments.
TEMPLATE_IMPORT_ROOTS=/workspace/data/template_imports
EVIDENCE_UPLOAD_DIR=/workspace/data/master_data_assets
EVIDENCE_UPLOAD_MAX_BYTES=52428800
TEMPLATE_RENDER_ROOT=/workspace/data/template_renders
TEMPLATE_BUNDLE_ROOT=/workspace/data/template_bundles

# Optional Mermaid render sidecar. If unset, backend uses deterministic SVG
# fallback renderers for local/dev execution.
MERMAID_RENDER_URL=http://mermaid-render:3000
MERMAID_RENDER_TIMEOUT_SECONDS=20

# Optional provider secrets reserved for agent-config setup.
# Keep these empty in git; set real values only in local/private env files.
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=

# Default seeded DB passwords such as admin123/editor123/reviewer123 are local
# bootstrap credentials only. Change or disable them before exposing the app.
